SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
DATABASE_URL=sqlite:///instance/afcyber_platform.db
ADMIN_EMAIL=admin@afcybersolutions.com.do
ADMIN_PASSWORD=replace-with-a-strong-initial-admin-password
FLASK_DEBUG=1
AUTO_CREATE_DB=1
SESSION_COOKIE_SECURE=0
BASE_URL=http://127.0.0.1:5000
MAX_UPLOAD_MB=60
SIGNING_SECRET=replace-with-a-random-signing-secret

# Email / SMTP
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_MAX_RETRIES=2
REQUIRE_SMTP=0
COMPANY_NOTIFICATION_EMAIL=info@afcybersolutions.com.do
SALES_EMAIL=
SUPPORT_EMAIL=

# Development storage. In production this must point outside the repo,
# for example a Render persistent disk mounted at /var/data/afcyber-storage.
PRIVATE_STORAGE_ROOT=storage
STORAGE_PROVIDER=render_disk

# Optional object-storage variables if this is later moved away from a disk.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
